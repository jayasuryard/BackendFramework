{
  "name": "@ryoforge17/cli",
  "version": "1.0.1",
  "description": "RyoForge Runtime Framework (RRF) - A CLI-driven, metadata-driven, method-oriented backend framework for Node.js & Express. Ships the `rrf` command and the runtime library.",
  "main": "lib/index.js",
  "type": "commonjs",
  "exports": {
    ".": "./lib/index.js",
    "./lib/*": "./lib/*.js"
  },
  "bin": {
    "rrf": "bin/rrf.js"
  },
  "files": [
    "lib/",
    "bin/",
    "README.md"
  ],
  "scripts": {
    "demo": "node examples/demo/express.js",
    "demo:ws": "node examples/demo/websocket.js",
    "demo:cron": "node examples/demo/cron.js",
    "test": "node --test",
    "prepublishOnly": "node -e \"require('./lib')\""
  },
  "keywords": [
    "framework",
    "backend",
    "cli",
    "express",
    "websocket",
    "serverless",
    "method-oriented",
    "rrf",
    "ryoforge"
  ],
  "author": "RyoForge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryoforge/rrf.git"
  },
  "homepage": "https://github.com/ryoforge/rrf#readme",
  "bugs": {
    "url": "https://github.com/ryoforge/rrf/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
