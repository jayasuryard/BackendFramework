{
  "name": "ryoforge-runtime-framework",
  "version": "1.0.0",
  "description": "RyoForge Runtime Framework (RRF) - A CLI-driven, metadata-driven, method-oriented backend framework for Node.js & Express.",
  "main": "lib/index.js",
  "type": "commonjs",
  "exports": {
    ".": "./lib/index.js",
    "./lib/*": "./lib/*.js"
  },
  "bin": {
    "rrf": "bin/rrf.js"
  },
  "scripts": {
    "start": "node express.js",
    "start:ws": "node websocket.js",
    "start:cron": "node cron.js",
    "dev": "nodemon express.js",
    "postman": "node postman.js",
    "swagger": "node -e \"require('./lib').swagger.write()\"",
    "test": "node --test"
  },
  "keywords": [
    "framework",
    "backend",
    "cli",
    "express",
    "method-oriented",
    "rrf",
    "ryoforge"
  ],
  "author": "RyoForge",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "cron-parser": "^4.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
